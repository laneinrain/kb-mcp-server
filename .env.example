# kb-mcp-server — copy to .env and fill in values
# Never commit .env (real secrets)

# --- CherryIn embedding API (required for ingest & health checks) ---
CHERRYIN_API_KEY=your_key_here
CHERRYIN_BASE_URL=https://open.cherryin.cc/v1

# --- Chroma vector store (HTTP sidecar) ---
CHROMA_HOST=localhost
CHROMA_PORT=8000
# Windows x64: npm chroma CLI is ARM64-only — run `pnpm setup:chroma` then `pnpm dev` uses Python `chroma run`
# Optional override: CHROMA_PYTHON_CLI=chroma

# --- Chunking defaults (bootstrap; Web UI can override in Phase 4) ---
CHUNK_SIZE=1024
CHUNK_OVERLAP=154

# --- Local data paths ---
DATA_DIR=./data
SQLITE_PATH=./data/sqlite/registry.db

# --- Backend (health API in Phase 1) ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=3000

# --- MCP HTTP (Streamable HTTP transport, Phase 3) ---
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3100

# --- Vector collection & embedding model ---
DEFAULT_COLLECTION=default
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
EMBEDDING_DIMENSIONS=1024

# --- Optional API key auth (Phase 4; off by default) ---
# When AUTH_ENABLED=true, set API_KEY; web UI prompts on 401; CLI reads from env.
# MCP HTTP auth is not configured here (deferred).
AUTH_ENABLED=false
# API_KEY=your_api_key_here
