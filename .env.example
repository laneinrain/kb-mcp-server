# kb-mcp-server — copy to .env and fill in values
# Never commit .env (real secrets)

# --- CherryIn embedding API (required for ingest & health checks) ---
CHERRYIN_API_KEY=your_key_here
CHERRYIN_BASE_URL=https://open.cherryin.cc

# --- Chroma vector store (HTTP sidecar) ---
CHROMA_HOST=localhost
CHROMA_PORT=8000

# --- Chunking defaults (bootstrap; Web UI can override in Phase 4) ---
CHUNK_SIZE=1024
CHUNK_OVERLAP=154

# --- Local data paths ---
DATA_DIR=./data
SQLITE_PATH=./data/sqlite/registry.db

# --- Backend (health API in Phase 1) ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=3000

# --- Vector collection & embedding model ---
DEFAULT_COLLECTION=default
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
EMBEDDING_DIMENSIONS=1024

# --- Optional API key auth (Phase 4; off by default) ---
# AUTH_ENABLED=false
# API_KEY=your_api_key_here
