# kb-mcp-server — copy to .env and fill in values
# Never commit .env (real secrets)

# --- CherryIn embedding API (required for ingest & health checks) ---
CHERRYIN_API_KEY=your_key_here
CHERRYIN_BASE_URL=https://open.cherryin.cc/v1

# --- Chroma vector store (HTTP sidecar) ---
CHROMA_HOST=localhost
CHROMA_PORT=8000
# Windows x64: npm chroma CLI is ARM64-only — run `pnpm setup:chroma` then `pnpm dev` uses Python `chroma run`
# Optional override: CHROMA_PYTHON_CLI=chroma

# --- Chunking defaults (bootstrap; Web UI can override in Phase 4) ---
CHUNK_SIZE=1024
CHUNK_OVERLAP=154

# --- Context retrieval defaults (bootstrap; Web UI can override in Phase 5) ---
# Chunks on each side of center for read_around (default window)
READ_AROUND_WINDOW_DEFAULT=1
# Maximum allowed read_around window (clamped silently)
READ_AROUND_WINDOW_MAX=3
# Max characters returned by read_around (truncates from window edges)
READ_AROUND_MAX_CHARS=32000
# Max chunks returned by read_file
READ_FILE_MAX_CHUNKS=50
# Max characters returned by read_file
READ_FILE_MAX_CHARS=64000

# --- Local data paths ---
DATA_DIR=./data
SQLITE_PATH=./data/sqlite/registry.db

# --- Backend (health API in Phase 1) ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=3000

# --- MCP HTTP (Streamable HTTP transport, Phase 3) ---
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3100

# --- Vector collection & embedding model ---
DEFAULT_COLLECTION=default
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
EMBEDDING_DIMENSIONS=1024

# --- Optional API key auth (Phase 4; off by default) ---
# When AUTH_ENABLED=true, set API_KEY; CLI uses Bearer API_KEY for REST ingest.
# With USER_AUTH_ENABLED=true, Web uses JWT login; CLI still uses global API_KEY (set AUTH_ENABLED=true).
# MCP HTTP auth is not configured here (deferred).
AUTH_ENABLED=false
# API_KEY=your_api_key_here

# --- User auth + CAS mock (Phase 7) ---
# Production: USER_AUTH_ENABLED=false unless you set JWT_SECRET.
# Dev (pnpm dev): mock user auth auto-enables — any non-empty password works with valid 工号.
USER_AUTH_ENABLED=false
# JWT_SECRET=your_jwt_secret_at_least_32_characters
# JWT_EXPIRES_IN=604800
# AUTH_SQLITE_PATH=./data/sqlite/auth.db
# AUTH_PROVIDER=cas
# CAS_MOCK=true
# CAS_SERVER_URL=https://cas.example.com/cas
