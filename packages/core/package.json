{
  "name": "@kb/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && node --input-type=module -e \"import { copyFileSync, mkdirSync } from 'node:fs'; import { dirname } from 'node:path'; mkdirSync('dist/registry', { recursive: true }); copyFileSync('src/registry/schema.sql', 'dist/registry/schema.sql');\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@kb/config": "workspace:*",
    "@langchain/textsplitters": "^1.0.1",
    "better-sqlite3": "^12.11.1",
    "chromadb": "^3.4.3",
    "gray-matter": "^4.0.3",
    "openai": "^5.12.2",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
